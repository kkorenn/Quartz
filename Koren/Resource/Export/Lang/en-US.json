    "CREDITS": "Credits",
    "CREDITS_BODY": "<color=#FFFFFF66>UI based on Overlayer (modlist.org)</color>\n<color=#FFFFFF88>Thank you for using KorenResourcePack.</color>\n<size=12><color=#FFFFFF33>\nLicensed under GPLv3</color></size>",
    "CREDITS_SUBTITLE": "by koren, sbrothers7, and more.",
    "DELETE_SHORT": "X",
    "DESC_ACCENT_COLOR": "Recolors the whole Koren UI. Middle-click to reset.",
    "DESC_AD_ON": "Deafens you on Discord once a run passes the percent below, and undeafens on death/finish. Needs your own Discord application: paste its Client ID, then Authorize.",
    "DESC_DL_MESSAGE": "Shown on the fail screen when a limit kills the run.",
    "DESC_DL_ON": "Counts misses and overloads during a run (useful with No Fail) and fails the run once a cap below is exceeded.",
    "DESC_FXRM_ON": "Strips the selected effect events from charts as they load. Reload the level to apply changes.",
    "DESC_FXRM_REMOVE_ALL_DECO": "Off keeps decorations that judgement-conditional events reference (hit/miss feedback) and removes the rest.",
    "DESC_FXRM_SAVE": "While the remover is on, the editor holds the stripped copy of the level — saving would overwrite the original chart, so it's blocked unless you enable this.",
    "DESC_JPOP_ON": "Suppresses the selected judgement popups — the text that pops up at the planet on every hit.",
    "DESC_JR_MESSAGE": "Shown on the fail screen when the restriction kills the run.",
    "DESC_JR_ON": "Instantly fails the run when a hit breaks the chosen rule.",
    "DESC_JUDGEMENT_ENABLED": "Top-center row of hit counts per judgement, from Overload through Perfect to Miss.",
    "DESC_KCB_ON": "Drops repeats of the same key arriving within the threshold — chattering switches fire multiple times per press. Blocked presses are logged.",
    "DESC_KEYVIEWER_DM_IMPORT": "Select a DM Note preset JSON file.",
    "DESC_KEYVIEWER_ENABLED": "On-screen key grid with per-key press counters, KPS and total presses.",
    "DESC_KEYVIEWER_KEYLABEL": "Custom caption for the selected key. Leave empty to derive it from the bound key.",
    "DESC_KEYVIEWER_RAIN": "Streaks rising from a key while it's held.",
    "DESC_KEYVIEWER_RAINWIDTH": "Streak width for the front key row. 0 matches each key's width.",
    "DESC_KEYVIEWER_RESETCOUNTS": "Clears every per-key press counter and the total.",
    "DESC_KEYVIEWER_SYNCLIMITER": "Overwrites the Key Limiter's allowed keys with the keys shown here, and keeps them matched when you rebind keys or switch styles.",
    "DESC_KL_CAPTURE": "Press any key to add/remove it from the allowed list. Escape cancels.",
    "DESC_KL_ON": "Only the allowed keys below count as gameplay hits while playing. Mouse buttons are always allowed; menus and the editor are unaffected.",
    "DESC_MIDDLE_CLICK_TO_SET_AS_DEFAULT": "Setting that restores an item to its default value when you middle-click on it.\nYou can identify it by a small dot at the top-left of the item",
    "DESC_OTTO_HIGHBPM_ON": "On: Otto uses the color below while the level's top BPM is 300+ (where vanilla turns him red). Off: the normal color is always used.",
    "DESC_OTTO_ON": "Replaces the editor's Otto (auto-play) icon with the mod's icon, tinted with the color below. Dimmed automatically while auto-play is off.",
    "DESC_OVERLAY_ENABLED": "Master switch for every overlay HUD — panels, progress bar, combo and judgement.",
    "DESC_PANEL_ADDSTAT": "Pick a stat to add to this panel.",
    "DESC_PANEL_LOCALIZESTATS": "Off: this panel's stat labels stay English (X-Acc, Max X-Acc…). On: they follow the UI language.",
    "DESC_PANEL_NAME": "Shown on the panel while reorganizing, and as this section's title.",
    "DESC_PANEL_PREFIX": "Extra line shown at the top of the panel.",
    "DESC_PANEL_STATCOLOR_MAXBPM": "BPM that maps to the 100% end of the gradient.",
    "DESC_PANEL_STATCOLOR_ON": "Tints this stat's value by blending the colors below across the stat's own 0–100% range.",
    "DESC_PANEL_STATCOLOR_PERFECT": "Overrides the gradient with this color while the stat sits at exactly 100% — v1's gold accuracy.",
    "DESC_PANELS_CREATE": "Adds a new empty panel. Name it, put stats on it, then drag it into place with Reorganize.",
    "DESC_PCOL_ON": "Recolors the planets (and their tails) with the colors below, overriding level events and skins.",
    "DESC_PROFILE_ADD": "Creates a new profile from your current settings and switches to it.",
    "DESC_PROFILE_IMPORT": "Loads a .krprofile file as a new profile. It won't be selected automatically.",
    "DESC_PROGRESSBAR_PREFILLSTART": "When a run starts mid-chart (checkpoint or editor play), the bar starts already filled up to that point instead of starting empty.",
    "DESC_PCOL_SEP_TAIL": "Off: tails use the ball color (with their own opacity). On: each planet's tail gets its own color.",
    "DESC_SHOW_TOOLTIP": "This is a Tooltip!",
    "DESC_TW_BCP": "Removes the planets' core and spark particles.",
    "DESC_TW_CP": "Strips checkpoint icons and behavior from the level — dying always restarts the run. Turning this off needs a level reload to bring icons back.",
    "DESC_TW_GLOW": "Suppresses the glow flash tiles get when the planet lands on them.",
    "DESC_TW_MENUMUSIC": "Mutes the theme song on the title and island-select screens. Takes effect immediately; gameplay music is untouched.",
    "DESC_TW_NOPAUSE": "While auto-play is on, the game pauses itself (e.g. when the window loses focus). This blocks those automatic pauses — pausing manually still works.",
    "DESC_TW_PGLOW": "Hides the glow sprite drawn around the planets.",
    "DESC_TW_RESULT_ACC": "Removes the Accuracy row from the detailed results screen.",
    "DESC_TW_RESULT_CHECKPOINTS": "Removes the Checkpoints Used row from the detailed results screen.",
    "DESC_TW_RESULT_MAXKEYS": "Removes the Maximum Used Keys row from the detailed results screen.",
    "DESC_TW_RESULT_XACC": "Removes the X-Accuracy row from the detailed results screen.",
    "DESC_TW_SCROLL": "Ignores mouse wheel input while a level is being played, so accidental scrolling can't affect the game mid-run.",
    "DESC_UIH_ON": "Hides the selected pieces of the game's own UI. Two profiles: Playing and Recording — the shortcut below flips between them mid-game.",
    "DESC_UIH_RECMODE": "Which profile is live right now: off = Playing, on = Recording.",
